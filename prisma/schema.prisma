generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model todoSet {
  id        String     @id
  name      String
  emoji     String?
  bgImg     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now())
  userId    String
  user      user       @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoTask  todoTask[]
}

model todoTask {
  id           String         @id
  content      String
  isFinish     Boolean        @default(false)
  isImportant  Boolean        @default(false)
  isToday      Boolean        @default(false)
  setId        String?
  dueDate      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  userId       String
  todoSet      todoSet?       @relation(fields: [setId], references: [id], onDelete: Cascade)
  user         user           @relation(fields: [userId], references: [id], onDelete: Cascade)
  todoTaskStep todoTaskStep[]
}

model todoTaskStep {
  id        String   @id
  content   String
  isFinish  Boolean  @default(false)
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  userId    String
  todoTask  todoTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model user {
  id             String         @id
  name           String
  email          String         @unique
  emailVerified  Boolean        @default(false)
  image          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now())
  setPreferences Json?
  account        account[]
  session        session[]
  todoSet        todoSet[]
  todoTask       todoTask[]
  todoTaskStep   todoTaskStep[]
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
}
